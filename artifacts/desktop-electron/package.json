{
  "name": "@workspace/desktop-electron",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dist": "pnpm run build && electron-builder --publish never"
  },
  "dependencies": {
    "electron": "^36.3.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron-builder": "^24.13.3",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  },
  "build": {
    "appId": "com.workspace.socialsimulate",
    "productName": "Social Simulate",
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
